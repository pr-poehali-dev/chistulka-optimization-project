# Цвета для вывода
class Colors:
    GREEN = '\033[92m'
    RED = '\033[91m'
    YELLOW = '\033[93m'
    BLUE = '\033[94m'
    CYAN = '\033[96m'
    RESET = '\033[0m'
    BOLD = '\033[1m'

def print_colored(text: str, color: str = Colors.RESET):
    """Цветной вывод в консоль"""
    print(f"{color}{text}{Colors.RESET}")

def log_response(test_name: str, response: requests.Response, expected_status: int, verbose: bool = True):
    """Логирование ответа API"""
    passed = response.status_code == expected_status
    status_color = Colors.GREEN if passed else Colors.RED
    status_icon = "✅" if passed else "❌"
    
    print(f"\n{Colors.BOLD}{'='*60}{Colors.RESET}")
    print(f"{Colors.BOLD}📝 {test_name}{Colors.RESET}")
    print(f"{'='*60}")
    print(f"{status_icon} Status: {response.status_code} (expected: {expected_status})")
    
    if not passed:
        print_colored(f"❌ FAILED - Expected {expected_status}, got {response.status_code}", Colors.RED)
    else:
        print_colored(f"✅ PASSED", Colors.GREEN)
    
    if verbose and response.status_code != expected_status:
        try:
            body = response.json()
            print(f"Response: {json.dumps(body, indent=2, ensure_ascii=False)[:300]}")
        except:
            print(f"Response body: {response.text[:200]}")
    
    return passed

def measure_response_time(func):
    """Декоратор для измерения времени ответа"""
    def wrapper(*args, **kwargs):
        start = time.time()
        result = func(*args, **kwargs)
        elapsed = (time.time() - start) * 1000
        print_colored(f"   ⏱️  Response time: {elapsed:.0f}ms", Colors.CYAN)
        return result
    return wrapper

@measure_response_time
def test_cors():
    """Тест CORS заголовков"""
    print(f"\n{Colors.BOLD}{'🔧 TESTING CORS'.center(60, '=')}{Colors.RESET}")
    
    required_headers = [
        "Access-Control-Allow-Origin",
        "Access-Control-Allow-Methods",
        "Access-Control-Allow-Headers"
    ]
    
    response = requests.options(API_URL, headers={
        "Origin": "https://example.com",
        "Access-Control-Request-Method": "GET",
        "Access-Control-Request-Headers": "Content-Type,X-Authorization"
    })
    
    print(f"Status: {response.status_code}")
    
    if response.status_code != 200:
        print_colored(f"❌ CORS preflight failed: {response.status_code}", Colors.RED)
        return False
    
    # Проверяем наличие необходимых заголовков
    missing_headers = []
    for header in required_headers:
        if header not in response.headers:
            missing_headers.append(header)
        else:
            print_colored(f"   ✅ {header}: {response.headers[header]}", Colors.GREEN)
    
    if missing_headers:
        print_colored(f"   ❌ Missing headers: {', '.join(missing_headers)}", Colors.RED)
        return False
    
    # Проверяем значение Allow-Origin
    if response.headers.get("Access-Control-Allow-Origin") != "*":
        print_colored(f"   ⚠️  Allow-Origin: {response.headers.get('Access-Control-Allow-Origin')} (not *)", Colors.YELLOW)
    
    return True

@measure_response_time
def test_without_auth():
    """Тесты без авторизации"""
    print(f"\n{Colors.BOLD}{'🔐 TESTING WITHOUT AUTH'.center(60, '=')}{Colors.RESET}")
    
    results = []
    test_cases = [
        ("GET / - No Auth", "GET", "/", None),
        ("POST /page - No Auth", "POST", "/page", {"page_key": "test", "title": "Test"}),
        ("POST /robots - No Auth", "POST", "/robots", {"content": "User-agent: *\nDisallow:"}),
    ]
    
    for name, method, path, body in test_cases:
        url = urljoin(API_URL, path)
        try:
            if method == "GET":
                response = requests.get(url)
            elif method == "POST":
                response = requests.post(url, json=body)
            
            results.append(log_response(name, response, 401, verbose=False))
        except Exception as e:
            print_colored(f"❌ {name} - Error: {str(e)}", Colors.RED)
            results.append(False)
    
    return all(results)

