def test_performance():
    """Тест производительности"""
    if not ADMIN_PASSWORD:
        return True
    
    print(f"\n{Colors.BOLD}{'⚡ TESTING PERFORMANCE'.center(60, '=')}{Colors.RESET}")
    
    headers = {"X-Authorization": f"Bearer {ADMIN_PASSWORD}"}
    response_times = []
    
    # Выполняем 5 запросов для замера
    for i in range(5):
        start = time.time()
        response = requests.get(API_URL, headers=headers)
        elapsed = (time.time() - start) * 1000
        response_times.append(elapsed)
        print_colored(f"   Request {i+1}: {elapsed:.0f}ms", Colors.CYAN)
        
        if response.status_code != 200:
            print_colored(f"   ❌ Failed request", Colors.RED)
            return False
    
    avg_time = sum(response_times) / len(response_times)
    max_time = max(response_times)
    min_time = min(response_times)
    
    print_colored(f"\n   📊 Performance Stats:", Colors.BOLD)
    print_colored(f"   Average: {avg_time:.0f}ms", Colors.GREEN if avg_time < 500 else Colors.YELLOW)
    print_colored(f"   Min: {min_time:.0f}ms", Colors.CYAN)
    print_colored(f"   Max: {max_time:.0f}ms", Colors.CYAN)
    
    return avg_time < 1000  # Должно быть меньше 1 секунды

