@measure_response_time
def test_with_correct_auth():
    """Тесты с правильной авторизацией"""
    if not ADMIN_PASSWORD:
        print_colored("\n⚠️ SKIPPING AUTH TESTS - SEO_ADMIN_PASSWORD not set", Colors.YELLOW)
        print_colored("   Set it with: export SEO_ADMIN_PASSWORD='your-password'", Colors.YELLOW)
        return True
    
    print(f"\n{Colors.BOLD}{'✅ TESTING WITH CORRECT AUTH'.center(60, '=')}{Colors.RESET}")
    
    headers = {"X-Authorization": f"Bearer {ADMIN_PASSWORD}"}
    results = []
    
    # GET all settings
    response = requests.get(API_URL, headers=headers)
    results.append(log_response("GET / - Get all settings", response, 200))
    
    if response.status_code == 200:
        data = response.json()
        print_colored(f"   📊 Pages count: {len(data.get('pages', []))}", Colors.CYAN)
        if data.get('pages'):
            print_colored(f"   📄 First page: {data['pages'][0].get('page_key')}", Colors.CYAN)
            print_colored(f"   📝 First title: {data['pages'][0].get('title', '')[:50]}", Colors.CYAN)
        print_colored(f"   🤖 Robots.txt length: {len(data.get('robots', ''))}", Colors.CYAN)
        
        # Проверка структуры данных
        if 'pages' in data and 'robots' in data:
            print_colored("   ✅ Response structure valid", Colors.GREEN)
        else:
            print_colored("   ⚠️  Response missing 'pages' or 'robots' fields", Colors.YELLOW)
    
    # POST update page
    timestamp = int(time.time())
    test_page = {
        "page_key": f"test-api-page-{timestamp}",
        "page_label": "Test API Page",
        "title": f"Test Page from API ({timestamp})",
        "description": "This is a test description for API testing",
        "keywords": "test,api,seo,automation",
        "schema_json": '{"@context":"https://schema.org","@type":"WebPage"}'
    }
    
    response = requests.post(f"{API_URL}/page", headers=headers, json=test_page)
    results.append(log_response("POST /page - Create/update page", response, 200))
    
    if response.status_code == 200:
        print_colored(f"   ✅ Page '{test_page['page_key']}' created/updated", Colors.GREEN)
    
    # POST update robots
    test_robots = f"""# Robots.txt - Updated by API test at {datetime.now().isoformat()}
User-agent: *
Allow: /
Disallow: /admin/
Disallow: /private/

Sitemap: https://example.com/sitemap.xml
Host: https://arenda-chistoty.online
"""
    
    response = requests.post(f"{API_URL}/robots", headers=headers, json={"content": test_robots})
    results.append(log_response("POST /robots - Update robots.txt", response, 200))
    
    # GET again to verify changes
    response = requests.get(API_URL, headers=headers)
    results.append(log_response("GET / - Verify changes", response, 200))
    
    if response.status_code == 200:
        data = response.json()
        test_page_found = next(
            (p for p in data.get('pages', []) if p['page_key'] == test_page['page_key']),
            None
        )
        if test_page_found:
            print_colored(f"   ✅ Test page found with title: {test_page_found['title']}", Colors.GREEN)
        else:
            print_colored(f"   ⚠️  Test page not found in response", Colors.YELLOW)
    
    return all(results)

@measure_response_time
def test_invalid_data():
    """Тесты с неверными данными"""
    if not ADMIN_PASSWORD:
        print_colored("\n⚠️ SKIPPING invalid data tests - need auth", Colors.YELLOW)
        return True
    
    print(f"\n{Colors.BOLD}{'⚠️ TESTING INVALID DATA'.center(60, '=')}{Colors.RESET}")
    
    headers = {"X-Authorization": f"Bearer {ADMIN_PASSWORD}"}
    results = []
    
    invalid_cases = [
        ("Missing page_key", {"title": "No Page Key"}, 400),
        ("Empty page_key", {"page_key": "", "title": "Empty Key"}, 400),
        ("Invalid schema_json", {"page_key": "test-invalid", "schema_json": "{invalid json}"}, 400),
        ("Very long title", {"page_key": "test-long", "title": "A" * 1000}, 200),  # Должен обрезаться
        ("Special chars in page_key", {"page_key": "test-page@#$%", "title": "Test"}, 400),
    ]
    
    for name, body, expected in invalid_cases:
        response = requests.post(f"{API_URL}/page", headers=headers, json=body)
        results.append(log_response(f"POST /page - {name}", response, expected, verbose=False))
    
    # Тест с очень большим robots.txt
    large_robots = "User-agent: *\nDisallow: /\n" * 10000
    response = requests.post(f"{API_URL}/robots", headers=headers, json={"content": large_robots})
    results.append(log_response("POST /robots - Large content (>100KB)", response, 400, verbose=False))
    
    return all(results)

