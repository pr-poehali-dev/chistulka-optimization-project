-- ============================================
-- ГЕНЕРАЦИЯ SITEMAP ИЗ БАЗЫ ДАННЫХ
-- ============================================

CREATE OR REPLACE FUNCTION generate_sitemap()
RETURNS TABLE (
    sitemap_xml TEXT,
    url_count INTEGER,
    generated_at TIMESTAMP
) AS $$
DECLARE
    v_sitemap TEXT;
    v_url_count INTEGER;
    v_base_url TEXT := 'https://arenda-chistoty.ru';
BEGIN
    -- Формируем sitemap
    WITH urls AS (
        SELECT 
            page_key,
            COALESCE(updated_at, NOW()) as lastmod,
            COALESCE(changefreq, 'weekly') as changefreq,
            CASE 
                WHEN priority >= 90 THEN 1.0
                WHEN priority >= 80 THEN 0.9
                WHEN priority >= 70 THEN 0.8
                WHEN priority >= 60 THEN 0.7
                WHEN priority >= 50 THEN 0.6
                WHEN priority >= 40 THEN 0.5
                ELSE 0.4
            END as priority
        FROM seo_settings
        WHERE no_index = FALSE
          AND page_key IS NOT NULL
          AND page_key != ''
        ORDER BY priority DESC, page_key
    )
    SELECT 
        string_agg(
            '  <url>' || E'\n' ||
            '    <loc>' || v_base_url || page_key || '</loc>' || E'\n' ||
            '    <lastmod>' || TO_CHAR(lastmod, 'YYYY-MM-DD') || '</lastmod>' || E'\n' ||
            '    <changefreq>' || changefreq || '</changefreq>' || E'\n' ||
            '    <priority>' || priority::TEXT || '</priority>' || E'\n' ||
            '  </url>',
            E'\n'
        ) INTO v_sitemap,
        COUNT(*) INTO v_url_count
    FROM urls;

    -- Оборачиваем в XML
    v_sitemap := '<?xml version="1.0" encoding="UTF-8"?>' || E'\n' ||
                  '<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">' || E'\n' ||
                  COALESCE(v_sitemap, '') || E'\n' ||
                  '</urlset>';

    RETURN QUERY SELECT v_sitemap, v_url_count, NOW();
END;
$$ LANGUAGE plpgsql;

-- ============================================
-- 2. СОЗДАНИЕ ТАБЛИЦЫ ДЛЯ ХРАНЕНИЯ SITEMAP
-- ============================================

CREATE TABLE IF NOT EXISTS seo_sitemap (
    id SERIAL PRIMARY KEY,
    content TEXT NOT NULL,
    url_count INTEGER DEFAULT 0,
    is_active BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP DEFAULT NOW()
);

CREATE INDEX idx_seo_sitemap_active ON seo_sitemap(is_active);
CREATE INDEX idx_seo_sitemap_created_at ON seo_sitemap(created_at DESC);

-- ============================================
-- 3. АВТОМАТИЧЕСКОЕ ОБНОВЛЕНИЕ SITEMAP
-- ============================================

CREATE OR REPLACE FUNCTION refresh_sitemap()
RETURNS JSONB AS $$
DECLARE
    v_sitemap TEXT;
    v_url_count INTEGER;
    v_result JSONB;
BEGIN
    -- Генерируем новый sitemap
    SELECT sitemap_xml, url_count INTO v_sitemap, v_url_count
    FROM generate_sitemap();
    
    -- Деактивируем старые версии
    UPDATE seo_sitemap SET is_active = FALSE WHERE is_active = TRUE;
    
    -- Вставляем новую версию
    INSERT INTO seo_sitemap (content, url_count, is_active)
    VALUES (v_sitemap, v_url_count, TRUE)
    RETURNING id INTO v_result;
    
    -- Логируем
    RAISE NOTICE '✅ Sitemap refreshed: % URLs, ID: %', v_url_count, v_result;
    
    RETURN jsonb_build_object(
        'status', 'success',
        'url_count', v_url_count,
        'id', v_result,
        'generated_at', NOW()
    );
END;
$$ LANGUAGE plpgsql;

-- ============================================
-- 4. РАСШИРЕННАЯ ГЕНЕРАЦИЯ С РАЗДЕЛЕНИЕМ
-- ============================================

CREATE OR REPLACE FUNCTION generate_sitemap_detailed()
RETURNS TABLE (
    section TEXT,
    urls JSONB,
    count INTEGER
) AS $$
DECLARE
    v_base_url TEXT := 'https://arenda-chistoty.ru';
BEGIN
    -- Главные страницы (приоритет >= 80)
    RETURN QUERY
    SELECT 
        'high_priority'::TEXT,
        jsonb_agg(
            jsonb_build_object(
                'loc', v_base_url || page_key,
                'lastmod', TO_CHAR(COALESCE(updated_at, NOW()), 'YYYY-MM-DD'),
                'changefreq', COALESCE(changefreq, 'weekly'),
                'priority', 
                    CASE 
                        WHEN priority >= 90 THEN 1.0
                        WHEN priority >= 80 THEN 0.9
                        ELSE 0.8
                    END
            )
        ) as urls,
        COUNT(*) as count
    FROM seo_settings
    WHERE no_index = FALSE
      AND priority >= 80
      AND page_key IS NOT NULL;
    
    -- Стандартные страницы (приоритет 50-79)
    RETURN QUERY
    SELECT 
        'standard'::TEXT,
        jsonb_agg(
            jsonb_build_object(
                'loc', v_base_url || page_key,
                'lastmod', TO_CHAR(COALESCE(updated_at, NOW()), 'YYYY-MM-DD'),
                'changefreq', COALESCE(changefreq, 'monthly'),
                'priority', 0.7
            )
        ) as urls,
        COUNT(*) as count
    FROM seo_settings
    WHERE no_index = FALSE
      AND priority BETWEEN 50 AND 79
      AND page_key IS NOT NULL;
    
    -- Низкоприоритетные страницы (приоритет < 50)
    RETURN QUERY
    SELECT 
        'low_priority'::TEXT,
        jsonb_agg(
            jsonb_build_object(
                'loc', v_base_url || page_key,
                'lastmod', TO_CHAR(COALESCE(updated_at, NOW()), 'YYYY-MM-DD'),
                'changefreq', 'yearly',
                'priority', 0.5
            )
        ) as urls,
        COUNT(*) as count
    FROM seo_settings
    WHERE no_index = FALSE
      AND priority < 50
      AND page_key IS NOT NULL;
    
    -- Специальные страницы (услуги)
    RETURN QUERY
    SELECT 
        'services'::TEXT,
        jsonb_agg(
            jsonb_build_object(
                'loc', v_base_url || page_key,
                'lastmod', TO_CHAR(COALESCE(updated_at, NOW()), 'YYYY-MM-DD'),
                'changefreq', 'monthly',
                'priority', 0.85
            )
        ) as urls,
        COUNT(*) as count
    FROM seo_settings
    WHERE no_index = FALSE
      AND page_key LIKE '/uslugi/%'
      AND page_key IS NOT NULL;
END;
$$ LANGUAGE plpgsql;

-- ============================================
-- 5. ФУНКЦИЯ ДЛЯ API (ВОЗВРАЩАЕТ JSON)
-- ============================================

CREATE OR REPLACE FUNCTION api_get_sitemap(
    p_format TEXT DEFAULT 'xml' -- 'xml' или 'json'
)
RETURNS TEXT AS $$
DECLARE
    v_sitemap TEXT;
    v_json JSONB;
BEGIN
    IF p_format = 'xml' THEN
        -- Возвращаем XML
        SELECT content INTO v_sitemap
        FROM seo_sitemap
        WHERE is_active = TRUE
        ORDER BY id DESC LIMIT 1;
        
        RETURN v_sitemap;
    ELSE
        -- Возвращаем JSON
        SELECT jsonb_build_object(
            'sitemap', (
                SELECT jsonb_agg(
                    jsonb_build_object(
                        'loc', v_base_url || page_key,
                        'lastmod', TO_CHAR(COALESCE(updated_at, NOW()), 'YYYY-MM-DD'),
                        'changefreq', COALESCE(changefreq, 'weekly'),
                        'priority', 
                            CASE 
                                WHEN priority >= 90 THEN 1.0
                                WHEN priority >= 80 THEN 0.9
                                WHEN priority >= 70 THEN 0.8
                                WHEN priority >= 60 THEN 0.7
                                ELSE 0.5
                            END
                    )
                )
                FROM seo_settings
                WHERE no_index = FALSE
                  AND page_key IS NOT NULL
            ),
            'total_urls', (
                SELECT COUNT(*)
                FROM seo_settings
                WHERE no_index = FALSE
                  AND page_key IS NOT NULL
            ),
            'generated_at', NOW()
        )::TEXT INTO v_json;
        
        RETURN v_json;
    END IF;
END;
$$ LANGUAGE plpgsql;

-- ============================================
-- 6. АВТОМАТИЧЕСКОЕ ОБНОВЛЕНИЕ ПРИ ИЗМЕНЕНИИ
-- ============================================

CREATE OR REPLACE FUNCTION trigger_refresh_sitemap()
RETURNS TRIGGER AS $$
BEGIN
    -- Обновляем sitemap при изменении seo_settings
    PERFORM refresh_sitemap();
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

