-- ============================================
-- 7. ПОЛУЧИТЬ SITEMAP В XML
-- ============================================

CREATE OR REPLACE FUNCTION get_sitemap_xml()
RETURNS TEXT AS $$
DECLARE
    v_result TEXT;
BEGIN
    SELECT content INTO v_result
    FROM seo_sitemap
    WHERE is_active = TRUE
    ORDER BY id DESC LIMIT 1;
    
    IF v_result IS NULL THEN
        -- Если нет сохраненной версии, генерируем
        SELECT sitemap_xml INTO v_result
        FROM generate_sitemap();
    END IF;
    
    RETURN v_result;
END;
$$ LANGUAGE plpgsql;

