-- ============================================
-- 9. РАСШИРЕННЫЙ SITEMAP С ДОПОЛНИТЕЛЬНЫМИ ДАННЫМИ
-- ============================================

CREATE OR REPLACE FUNCTION generate_extended_sitemap()
RETURNS TEXT AS $$
DECLARE
    v_sitemap TEXT;
    v_base_url TEXT := 'https://arenda-chistoty.ru';
    v_now DATE := CURRENT_DATE;
BEGIN
    WITH url_data AS (
        SELECT 
            page_key,
            COALESCE(updated_at, NOW()) as lastmod,
            COALESCE(changefreq, 'weekly') as changefreq,
            CASE 
                WHEN page_key = '/' THEN 1.0
                WHEN page_key LIKE '/uslugi/%' THEN 0.9
                WHEN page_key = '/nashi-raboty' THEN 0.8
                WHEN page_key LIKE '/blog/%' THEN 0.7
                ELSE 0.6
            END as priority,
            -- Дополнительные метаданные
            page_label,
            title
        FROM seo_settings
        WHERE no_index = FALSE
          AND page_key IS NOT NULL
          AND page_key != ''
        ORDER BY priority DESC, page_key
    )
    SELECT 
        '<?xml version="1.0" encoding="UTF-8"?>' || E'\n' ||
        '<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"' ||
        ' xmlns:news="http://www.google.com/schemas/sitemap-news/0.9"' ||
        ' xmlns:xhtml="http://www.w3.org/1999/xhtml"' ||
        ' xmlns:mobile="http://www.google.com/schemas/sitemap-mobile/1.0"' ||
        ' xmlns:image="http://www.google.com/schemas/sitemap-image/1.1">' || E'\n' ||
        string_agg(
            '  <url>' || E'\n' ||
            '    <loc>' || v_base_url || page_key || '</loc>' || E'\n' ||
            '    <lastmod>' || TO_CHAR(lastmod, 'YYYY-MM-DD') || '</lastmod>' || E'\n' ||
            '    <changefreq>' || changefreq || '</changefreq>' || E'\n' ||
            '    <priority>' || priority::TEXT || '</priority>' || E'\n' ||
            '    <xhtml:link rel="alternate" hreflang="ru" href="' || v_base_url || page_key || '"/>' || E'\n' ||
            '  </url>',
            E'\n'
        ) || E'\n' ||
        '</urlset>' INTO v_sitemap
    FROM url_data;

    RETURN v_sitemap;
END;
$$ LANGUAGE plpgsql;

-- ============================================
-- 10. ПРОВЕРКА SITEMAP
-- ============================================

CREATE OR REPLACE FUNCTION validate_sitemap()
RETURNS TABLE (
    check_type TEXT,
    status TEXT,
    details TEXT
) AS $$
DECLARE
    v_url_count INTEGER;
    v_duplicates INTEGER;
    v_missing_urls TEXT[];
BEGIN
    -- Проверка количества URL
    SELECT COUNT(*) INTO v_url_count
    FROM seo_settings
    WHERE no_index = FALSE;
    
    RETURN QUERY SELECT 
        'URL Count'::TEXT,
        CASE 
            WHEN v_url_count > 0 THEN '✅ OK'
            ELSE '❌ ERROR'
        END,
        format('Found %s URLs', v_url_count)::TEXT;
    
    -- Проверка дубликатов
    SELECT COUNT(*) - COUNT(DISTINCT page_key) INTO v_duplicates
    FROM seo_settings
    WHERE no_index = FALSE;
    
    RETURN QUERY SELECT 
        'Duplicates'::TEXT,
        CASE 
            WHEN v_duplicates = 0 THEN '✅ OK'
            ELSE '⚠️ WARNING'
        END,
        format('Found %s duplicate URLs', v_duplicates)::TEXT;
    
    -- Проверка обязательных страниц
    WITH required_pages AS (
        SELECT unnest(ARRAY[
            '/',
            '/uslugi/himchistka-divanov',
            '/uslugi/himchistka-matrasov',
            '/nashi-raboty'
        ]) as page_key
    )
    SELECT array_agg(r.page_key) INTO v_missing_urls
    FROM required_pages r
    LEFT JOIN seo_settings s ON s.page_key = r.page_key
    WHERE s.page_key IS NULL;
    
    RETURN QUERY SELECT 
        'Required Pages'::TEXT,
        CASE 
            WHEN array_length(v_missing_urls, 1) IS NULL THEN '✅ OK'
            ELSE '⚠️ WARNING'
        END,
        format('Missing: %s', COALESCE(array_to_string(v_missing_urls, ', '), 'None'))::TEXT;
    
    -- Проверка последнего обновления
    RETURN QUERY SELECT 
        'Last Update'::TEXT,
        '✅ OK'::TEXT,
        format('Last sitemap update: %s', 
            (SELECT TO_CHAR(created_at, 'YYYY-MM-DD HH24:MI:SS') 
             FROM seo_sitemap 
             WHERE is_active = TRUE 
             ORDER BY id DESC LIMIT 1)
        )::TEXT;
END;
$$ LANGUAGE plpgsql;

-- ============================================
-- 11. ЗАПУСК ВСЕХ ПРОВЕРОК
-- ============================================

SELECT * FROM validate_sitemap();

-- ============================================
-- 12. ЭКСПОРТ SITEMAP В ФАЙЛ
-- ============================================

CREATE OR REPLACE FUNCTION export_sitemap_to_file()
RETURNS TEXT AS $$
DECLARE
    v_content TEXT;
    v_filename TEXT;
BEGIN
    -- Получаем текущий sitemap
    SELECT content INTO v_content
    FROM seo_sitemap
    WHERE is_active = TRUE
    ORDER BY id DESC LIMIT 1;
    
    -- Создаем имя файла
    v_filename := '/tmp/sitemap_' || TO_CHAR(NOW(), 'YYYYMMDD_HH24MISS') || '.xml';
    
    -- Экспортируем
    PERFORM pg_file_write(v_filename, v_content, false);
    
    RETURN format('✅ Sitemap exported to: %s (size: %s bytes)', 
        v_filename, 
        LENGTH(v_content)
    );
END;
$$ LANGUAGE plpgsql;

